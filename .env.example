# Server Configuration
PORT=7861
HOST=0.0.0.0
NODE_ENV=production

# Security
# Generate a strong random string for JWT_SECRET (min 64 chars)
# You can generate one with: openssl rand -hex 32  (produces 64 hex chars)
JWT_SECRET=

# Admin Credentials (optional - auto-generated if not provided)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# Database
# DATABASE_PATH=./data/chatflowui.db

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100

# Subpath deployment (reverse proxy only — e.g. Nginx/Caddy at /7861/).
# Leave unset for direct port access; setting it without a proxy breaks the admin UI.
# BASE_PATH=/7861/

# Public base URL used when generating widget embed codes.
# Recommended in production — otherwise the request Host header is used.
# PUBLIC_URL=https://chat.yourdomain.com

# CORS
# Origin of the admin dashboard if hosted separately from the server
# ADMIN_ORIGIN=https://admin.yourdomain.com
# Global comma-separated allow-list of origins (in addition to per-chatbot allowed origins)
# CORS_ALLOWED_ORIGINS=https://site-a.com,https://site-b.com
